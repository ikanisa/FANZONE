# FANZONE local/development release environment.
# Copy to .env for local tooling only. Never commit real .env files.

# Flutter/runtime Supabase client config. Browser/mobile safe anon key only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Backend/deployment-only secrets. These are for Supabase Edge Functions and
# release tooling only. Never expose these in Flutter, Vite, or public web apps.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
EDGE_SERVICE_ROLE_KEY=replace-with-dedicated-edge-service-role-key
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=sbp_replace_with_personal_access_token

# Public web/app URLs used for QR codes, app links, reviewer notes, and TV join.
PUBLIC_SITE_URL=https://fanzone.example.com
APP_PUBLIC_URL=https://fanzone.example.com
VITE_GUEST_APP_URL=https://fanzone.example.com
VITE_PUBLIC_APP_URL=https://fanzone.example.com
VITE_TV_DISPLAY_URL=https://screen.fanzone.example.com

# Browser-safe web/PWA config. The deploy script maps SUPABASE_* to VITE_* when
# these are not supplied explicitly.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_ENV=development

# WhatsApp Cloud API OTP Edge Function config.
WABA_ACCESS_TOKEN=replace-with-whatsapp-cloud-api-token
WABA_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WABA_OTP_TEMPLATE_NAME=otp_login
FANZONE_JWT_SECRET=replace-with-supabase-jwt-secret
OTP_EXPIRY_SECONDS=600
WHATSAPP_SESSION_ACCESS_EXPIRY_SECONDS=3600
WHATSAPP_SESSION_REFRESH_EXPIRY_SECONDS=2592000
MAX_OTP_REQUESTS_PER_IP=10
FANZONE_EDGE_ALLOWED_ORIGINS=https://fanzone.example.com,https://admin.fanzone.example.com,https://venues.fanzone.example.com,https://screen.fanzone.example.com
FANZONE_EDGE_ALLOW_WILDCARD_CORS=false

# Optional live WhatsApp auth smoke coverage for tool/supabase_whatsapp_auth_smoke.sh
# Dedicated Google Play reviewer / store-submission credentials
# WHATSAPP_AUTH_TEST_PHONE=+250788767816
# WHATSAPP_AUTH_TEST_OTP=123456

# External payment instruction config. MVP uses guidance only, not payment APIs.
PAYMENT_RWANDA_MOMO_USSD=*182*8*1#
PAYMENT_EUROPE_REVOLUT_LINK=https://revolut.me/yourvenue

# Scheduled jobs and Edge Function protection.
CRON_SECRET=replace-with-random-cron-secret
PUSH_NOTIFY_SECRET=replace-with-random-push-secret
GOOGLE_SERVICE_ACCOUNT_JSON=replace-with-firebase-service-account-json
POOL_SOCIAL_CARD_BUCKET=pool-social-cards
GEMINI_API_KEY=replace-with-gemini-key-if-menu-ocr-enabled

# Cloudflare Pages release tooling.
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_WEBSITE_PROJECT_NAME=fanzone-website
CLOUDFLARE_ADMIN_PROJECT_NAME=fanzone-admin
CLOUDFLARE_VENUE_PORTAL_PROJECT_NAME=fanzone-venue-portal
CLOUDFLARE_TV_DISPLAY_PROJECT_NAME=fanzone-tv-display
CLOUDFLARE_PAGES_BRANCH=main
