# FANZONE staging release environment.
# Copy to .env.staging or your secret manager. Never commit real values.

SUPABASE_URL=https://your-staging-project-ref.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-service-role-key
EDGE_SERVICE_ROLE_KEY=replace-with-staging-edge-service-role-key
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.your-staging-project-ref.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=sbp_replace_with_staging_personal_access_token

PUBLIC_SITE_URL=https://staging.fanzone.example.com
APP_PUBLIC_URL=https://staging.fanzone.example.com
VITE_GUEST_APP_URL=https://staging.fanzone.example.com
VITE_PUBLIC_APP_URL=https://staging.fanzone.example.com
VITE_TV_DISPLAY_URL=https://staging-screen.fanzone.example.com

VITE_SUPABASE_URL=https://your-staging-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
VITE_APP_ENV=staging

WABA_ACCESS_TOKEN=replace-with-staging-whatsapp-cloud-api-token
WABA_PHONE_NUMBER_ID=replace-with-staging-whatsapp-phone-number-id
WABA_OTP_TEMPLATE_NAME=otp_login
FANZONE_JWT_SECRET=replace-with-staging-supabase-jwt-secret
OTP_EXPIRY_SECONDS=600
WHATSAPP_SESSION_ACCESS_EXPIRY_SECONDS=3600
WHATSAPP_SESSION_REFRESH_EXPIRY_SECONDS=2592000
MAX_OTP_REQUESTS_PER_IP=10
WHATSAPP_AUTH_TEST_PHONE=+15555550123
WHATSAPP_AUTH_TEST_OTP=123456

PAYMENT_RWANDA_MOMO_USSD=*182*8*1#
PAYMENT_EUROPE_REVOLUT_LINK=https://revolut.me/stagingvenue

CRON_SECRET=replace-with-staging-cron-secret
PUSH_NOTIFY_SECRET=replace-with-staging-push-secret
GOOGLE_SERVICE_ACCOUNT_JSON=replace-with-staging-firebase-service-account-json
POOL_SOCIAL_CARD_BUCKET=pool-social-cards-staging
GEMINI_API_KEY=replace-with-staging-gemini-key-if-menu-ocr-enabled

CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_WEBSITE_PROJECT_NAME=fanzone-website-staging
CLOUDFLARE_ADMIN_PROJECT_NAME=fanzone-admin-staging
CLOUDFLARE_VENUE_PORTAL_PROJECT_NAME=fanzone-venue-portal-staging
CLOUDFLARE_TV_DISPLAY_PROJECT_NAME=fanzone-tv-display-staging
CLOUDFLARE_PAGES_BRANCH=staging
