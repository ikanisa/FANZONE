# FANZONE production release environment.
# Copy to an ignored .env.production file or secret manager. Never commit real values.

SUPABASE_URL=https://your-production-project-ref.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-production-service-role-key
EDGE_SERVICE_ROLE_KEY=replace-with-production-edge-service-role-key
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.your-production-project-ref.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=sbp_replace_with_production_personal_access_token

PUBLIC_SITE_URL=https://fanzone.example.com
APP_PUBLIC_URL=https://fanzone.example.com
VITE_GUEST_APP_URL=https://fanzone.example.com
VITE_PUBLIC_APP_URL=https://fanzone.example.com
VITE_TV_DISPLAY_URL=https://screen.fanzone.example.com

VITE_SUPABASE_URL=https://your-production-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key
VITE_APP_ENV=production

WABA_ACCESS_TOKEN=replace-with-production-whatsapp-cloud-api-token
WABA_PHONE_NUMBER_ID=replace-with-production-whatsapp-phone-number-id
WABA_OTP_TEMPLATE_NAME=otp_login
FANZONE_JWT_SECRET=replace-with-production-supabase-jwt-secret
OTP_EXPIRY_SECONDS=600
WHATSAPP_SESSION_ACCESS_EXPIRY_SECONDS=3600
WHATSAPP_SESSION_REFRESH_EXPIRY_SECONDS=2592000
MAX_OTP_REQUESTS_PER_IP=10

# Optional production-isolated reviewer route. Use only for store review.
# WHATSAPP_AUTH_TEST_PHONE=+15555550123
# WHATSAPP_AUTH_TEST_OTP=123456
# WHATSAPP_AUTH_TEST_EXPIRY=2026-12-31T23:59:59Z

PAYMENT_RWANDA_MOMO_USSD=*182*8*1#
PAYMENT_EUROPE_REVOLUT_LINK=https://revolut.me/yourvenue

CRON_SECRET=replace-with-production-cron-secret
PUSH_NOTIFY_SECRET=replace-with-production-push-secret
GOOGLE_SERVICE_ACCOUNT_JSON=replace-with-production-firebase-service-account-json
POOL_SOCIAL_CARD_BUCKET=pool-social-cards
GEMINI_API_KEY=replace-with-production-gemini-key-if-menu-ocr-enabled

CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_WEBSITE_PROJECT_NAME=fanzone-website
CLOUDFLARE_ADMIN_PROJECT_NAME=fanzone-admin
CLOUDFLARE_VENUE_PORTAL_PROJECT_NAME=fanzone-venue-portal
CLOUDFLARE_TV_DISPLAY_PROJECT_NAME=fanzone-tv-display
CLOUDFLARE_PAGES_BRANCH=main
