{
  "name": "@fanzone/website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:canonical": "node ../../tool/canonical_web_source.mjs sync",
    "check:canonical": "node ../../tool/canonical_web_source.mjs check",
    "validate:release-metadata": "node ../../tool/validate_website_release_metadata.mjs",
    "dev": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
