# FANZONE Admin Panel — browser-safe environment variables.
# Copy this file to .env locally or configure these in Cloudflare Pages.
# Do not add service-role keys, database URLs, WhatsApp tokens, or admin secrets.

# Supabase connection (required for WhatsApp OTP admin sign-in)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App environment
VITE_APP_ENV=production

# Production uses the Cloudflare Pages BFF worker and HttpOnly cookies.
# Use "browser" only for local development without Wrangler/Pages Functions.
VITE_PRIVILEGED_SESSION_MODE=bff

# Optional: local-only demo mode when Supabase env is missing
# VITE_ALLOW_DEMO_MODE=false
